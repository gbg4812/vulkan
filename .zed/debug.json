// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug app",
    "build": {
      "command": "make",
      "args": ["-j32"],
      "cwd": "$ZED_WORKTREE_ROOT/build/",
      "use_new_terminal": true,
      "shell": {
        "program": "zsh",
      },
    },
    "program": "$ZED_WORKTREE_ROOT/build/app",
    "args": ["data/models/EasyModels/scene.obj"],
    "cwd": "$ZED_WORKTREE_ROOT/tests/",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
]
